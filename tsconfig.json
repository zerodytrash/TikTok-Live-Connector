{
    "include": [
        "src/**/*"
    ],
    "compilerOptions": {
        "allowJs": false,
        "strictNullChecks": true,
        "moduleResolution": "Bundler",
        "module": "ESNext",
        "target": "ES2022",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "outDir": "dist",
        "declarationMap": true,
        "sourceMap": true,
        "inlineSources": true,
        "rootDir": "src",
        "typeRoots": [
            "node_modules/@types",
            "src/types"
        ],
        "resolveJsonModule": true,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    }
}
